# Database
DATABASE_URL=postgresql://macrosift:macrosift@postgres:5432/macrosift
REDIS_URL=redis://redis:6379

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_BOT_USERNAME=MacroSiftBot

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Market Data APIs (required for OHLCV charts and quotes)
TWELVE_DATA_API_KEY=your-twelve-data-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Optional: MT4 history (only if you have MetaTrader 4 installed)
# Set this to your MT4 history directory path, then start with: docker compose --profile mt4 up -d
MT4_HOST_HISTORY=/path/to/your/mt4/history

# Email (Resend)
RESEND_API_KEY=re_xxx

# Cron
CRON_SECRET=change-me

# Trading Signals
TRADING_SIGNALS_API_KEY=your-signals-api-key
